rameters, verdict thresholds, projected\ntrajectory functions, and curated quality-marker dictionaries) is not disclosed\nin this deposit and remains protected commercial trade-secret material under\npsylligent ltd. Reverse-engineering or reconstruction is prohibited.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenticracy.ai/schemas/audit-record/v2.7-public.json",
  "title": "Agenticracy Public Audit Record (v2.7-public-only)",
  "description": "Public audit record schema. Contains only the public Agenticracy measurement layer: S, P, O, N + confidences/justifications, public derived (R_public, D_public, G_public), symmetric classification (state_class, recommended_action_class), cost-quality telemetry, evidence, ethics, and model metadata. Private high-resolution engine outputs are NOT in this schema.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/AuditRecord"
    },
    {
      "$ref": "#/$defs/RefusalRecord"
    }
  ],
  "$defs": {
    "ConfidenceBand": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "Score": {
      "type": "number",
      "minimum": 1.0,
      "maximum": 10.0
    },
    "EvidenceSource": {
      "type": "object",
      "required": [
        "source_type",
        "title",
        "claim_supported",
        "source_confidence"
      ],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "website",
            "paper",
            "news",
            "filing",
            "social",
            "database",
            "other"
          ]
        },
        "title": {
          "type": "string"
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "date_accessed_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "claim_supported": {
          "type": "string",
          "enum": [
            "S",
            "P",
            "O",
            "N",
            "mixed"
          ]
        },
        "source_confidence": {
          "$ref": "#/$defs/ConfidenceBand"
        },
        "notes": {
          "type": "string"
        },
        "engine_type": {
          "type": "string",
          "enum": [
            "public_baseline",
            "private_proprietary",
            "hybrid_research"
          ],
          "description": "Scoring engine class used for computed scores."
        },
        "R_public": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 10.0,
          "description": "Public baseline Ground Reality Estimate: (P+O)/2."
        },
        "D_public": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 9.0,
          "description": "Public baseline Narrative Debt: max(0,S-R_public)."
        },
        "G_public": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 10.0,
          "description": "Public baseline Congruence Score computed from disclosed formula."
        },
        "private_scores_withheld": {
          "type": "boolean",
          "description": "True when proprietary scores are withheld."
        }
      },
      "additionalProperties": false
    },
    "RefusalRecord": {
      "type": "object",
      "required": [
        "refused",
        "reason",
        "subject",
        "run_id",
        "audit_date_utc"
      ],
      "properties": {
        "refused": {
          "const": true
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "subject": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        },
        "audit_date_utc": {
          "type": "string",
          "format": "date-time"
        },
        "engine_type": {
          "type": "string",
          "enum": [
            "public_baseline",
            "private_proprietary",
            "hybrid_research"
          ],
          "description": "Scoring engine class used for computed scores."
        },
        "R_public": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 10.0,
          "description": "Public baseline Ground Reality Estimate: (P+O)/2."
        },
        "D_public": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 9.0,
          "description": "Public baseline Narrative Debt: max(0,S-R_public)."
        },
        "G_public": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 10.0,
          "description": "Public baseline Congruence Score computed from disclosed formula."
        },
        "private_scores_withheld": {
          "type": "boolean",
          "description": "True when proprietary scores are withheld."
        }
      },
      "additionalProperties": false
    },
    "AuditRecord": {
      "type": "object",
      "required": [
        "subject",
        "audit_year",
        "audit_date_utc",
        "experiment_id",
        "run_id",
        "repeat_index",
        "paper_version",
        "public_schema_version",
        "prompt_version",
        "scorer_type",
        "scorer_id",
        "calibration_class",
        "entity_type",
        "living_person",
        "public_figure_or_role_relevant_entity",
        "data_sensitivity",
        "privacy_risk",
        "publication_status",
        "ethics_notes",
        "current_S",
        "S_confidence",
        "current_P",
        "P_confidence",
        "current_O",
        "O_confidence",
        "current_N",
        "N_confidence",
        "evidence_sources",
        "source_confidence",
        "contested_evidence",
        "missing_evidence",
        "evidence_cutoff_date",
        "notes_on_uncertainty",
        "overall_confidence",
        "verdict"
      ],
      "properties": {
        "subject": {
          "type": "string"
        },
        "audit_year": {
          "type": "string",
          "pattern": "^[0-9]{4}$"
        },
        "audit_date_utc": {
          "type": "string",
          "format": "date-time"
        },
        "day_number": {
          "type": "integer",
          "minimum": 0
        },
        "agent_id": {
          "type": "string"
        },
        "deployment_context": {
          "type": "string"
        },
        "experiment_id": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        },
        "repeat_index": {
          "type": "integer",
          "minimum": 1
        },
        "paper_version": {
          "type": "string"
        },
        "public_schema_version": {
          "type": "string"
        },
        "prompt_version": {
          "type": "string"
        },
        "scorer_type": {
          "type": "string",
          "enum": [
            "human",
            "ai",
            "hybrid"
          ]
        },
        "scorer_id": {
          "type": "string"
        },
        "model_provider": {
          "type": [
            "string",
            "null"
          ]
        },
        "model_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "model_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "temperature": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 2
        },
        "top_p": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "calibration_class": {
          "type": "string"
        },
        "entity_type": {
          "type": "string",
          "enum": [
            "individual",
            "organisation",
            "project",
            "policy",
            "agent",
            "other"
          ]
        },
        "living_person": {
          "type": "boolean"
        },
        "public_figure_or_role_relevant_entity": {
          "type": "boolean"
        },
        "data_sensitivity": {
          "$ref": "#/$defs/ConfidenceBand"
        },
        "privacy_risk": {
          "$ref": "#/$defs/ConfidenceBand"
        },
        "publication_status": {
          "type": "string",
          "enum": [
            "private",
            "aggregated",
            "pseudonymised",
            "public"
          ]
        },
        "ethics_notes": {
          "type": "string"
        },
        "current_S": {
          "$ref": "#/$defs/Score"
        },
        "S_confidence": {
          "$ref": "#/$defs/ConfidenceBand"
        },
        "current_P": {
          "$ref": "#/$defs/Score"
        },
        "P_confidence": {
          "$ref": "#/$defs/ConfidenceBand"
        },
        "current_O": {
          "$ref": "#/$defs/Score"
        },
        "O_confidence": {
          "$ref": "#/$defs/ConfidenceBand"
        },
        "current_N": {
          "$ref": "#/$defs/Score"
        },
        "N_confidence": {
          "$ref": "#/$defs/ConfidenceBand"
        },
        "N_justification": {
          "type": "string"
        },
        "evidence_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/EvidenceSource"
          }
        },
        "source_confidence": {
          "$ref": "#/$defs/ConfidenceBand"
        },
        "contested_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_cutoff_date": {
          "type": "string",
          "format": "date-time"
        },
        "notes_on_uncertainty": {
          "type": "string"
        },
        "prediction_or_hypothesis": {
          "type": "string"
        },
        "expected_correction_window": {
          "type": "string"
        },
        "intervention_recommended": {
          "type": "string"
        },
        "intervention_taken": {
          "type": "string"
        },
        "observed_outcome": {
          "type": "string"
        },
        "follow_up_required": {
          "type": "boolean"
        },
        "follow_up_date_utc": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "reality_correction_event_observed": {
          "type": "boolean"
        },
        "reality_correction_event_type": {
          "type": "string"
        },
        "falsification_notes": {
          "type": "string"
        },
        "cross_model_panel": {
          "type": "object",
          "properties": {
            "panel_size": {
              "type": "integer",
              "minimum": 1
            },
            "model_rank_or_role": {
              "type": "string"
            },
            "independent_run": {
              "type": "boolean"
            },
            "prior_outputs_visible": {
              "type": "boolean"
            },
            "adjudication_required": {
              "type": "boolean"
            },
            "adjudication_notes": {
              "type": "string"
            },
            "engine_type": {
              "type": "string",
              "enum": [
                "public_baseline",
                "private_proprietary",
                "hybrid_research"
              ],
              "description": "Scoring engine class used for computed scores."
            },
            "R_public": {
              "type": "number",
              "minimum": 1.0,
              "maximum": 10.0,
              "description": "Public baseline Ground Reality Estimate: (P+O)/2."
            },
            "D_public": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 9.0,
              "description": "Public baseline Narrative Debt: max(0,S-R_public)."
            },
            "G_public": {
              "type": "number",
              "minimum": 1.0,
              "maximum": 10.0,
              "description": "Public baseline Congruence Score computed from disclosed formula."
            },
            "private_scores_withheld": {
              "type": "boolean",
              "description": "True when proprietary scores are withheld."
            }
          },
          "additionalProperties": false
        },
        "overall_confidence": {
          "$ref": "#/$defs/ConfidenceBand"
        },
        "verdict": {
          "type": "string",
          "minLength": 1
        },
        "engine_type": {
          "type": "string",
          "enum": [
            "public_baseline",
            "private_proprietary",
            "hybrid_research"
          ],
          "description": "Scoring engine class used for computed scores."
        },
        "R_public": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 10.0,
          "description": "Public baseline Ground Reality Estimate: (P+O)/2."
        },
        "D_public": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 9.0,
          "description": "Public baseline Narrative Debt: max(0,S-R_public)."
        },
        "G_public": {
          "type": "number",
          "minimum": 1.0,
          "maximum": 10.0,
          "description": "Public baseline Congruence Score computed from disclosed formula."
        },
        "private_scores_withheld": {
          "type": "boolean",
          "description": "True when proprietary scores are withheld."
        },
        "classification": {
          "$ref": "#/$defs/Classification"
        },
        "cost_quality": {
          "$ref": "#/$defs/CostQuality"
        }
      },
      "additionalProperties": false
    },
    "StateClass": {
      "type": "string",
      "enum": [
        "extractive_extreme",
        "congruent_center",
        "pathological_humility",
        "noise_dominant",
        "ambiguous_mixed"
      ]
    },
    "ActionClass": {
      "type": "string",
      "enum": [
        "reduce_S",
        "increase_P",
        "increase_S",
        "reduce_N",
        "maintain",
        "mixed"
      ]
    },
    "Classification": {
      "type": "object",
      "required": [
        "state_class",
        "recommended_action_class"
      ],
      "properties": {
        "state_class": {
          "$ref": "#/$defs/StateClass"
        },
        "state_class_justification": {
          "type": "string"
        },
        "recommended_action_class": {
          "$ref": "#/$defs/ActionClass"
        },
        "recommended_action_justification": {
          "type": "string"
        }
      }
    },
    "CostQuality": {
      "type": "object",
      "description": "Per-cell cost-quality telemetry. Public for reproducibility of compute-vs-quality trade-off claims.",
      "properties": {
        "input_tokens": {
          "type": "integer"
        },
        "output_tokens": {
          "type": "integer"
        },
        "reasoning_tokens": {
          "type": "integer"
        },
        "total_tokens": {
          "type": "integer"
        },
        "latency_seconds": {
          "type": "number"
        },
        "cost_usd": {
          "type": "number"
        },
        "reasoning_text_chars": {
          "type": "integer"
        },
        "condition_id": {
          "type": "string",
          "enum": [
            "C1",
            "C2",
            "C3"
          ]
        }
      }
    }
  }
}